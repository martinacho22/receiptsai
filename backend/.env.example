# ReceiptsAI — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env!

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-this-to-a-long-random-string

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:6543/postgres

# Twilio (WhatsApp Business API)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# OpenAI (GPT-4o Vision for receipt parsing)
OPENAI_API_KEY=sk-proj-your-key-here

# File Storage (Cloudflare R2 — S3-compatible, cheaper)
STORAGE_ENDPOINT=https://YOUR_ACCOUNT.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=your_r2_access_key
STORAGE_SECRET_ACCESS_KEY=your_r2_secret_key
STORAGE_BUCKET_NAME=receiptsai-uploads
STORAGE_PUBLIC_URL=https://pub-YOUR_HASH.r2.dev

# Mercado Pago (payment processing for Mexico)
MERCADO_PAGO_ACCESS_TOKEN=TEST-your-test-token
MERCADO_PAGO_PUBLIC_KEY=TEST-your-public-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=change-this-too-another-long-random-string
JWT_EXPIRY_HOURS=168
